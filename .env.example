# ============================================================
# AegisInvest AI — environment configuration (EXAMPLE ONLY)
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- Application ---
APP_ENV=development                 # development | test | production
APP_SECRET_KEY=change-me-generate-a-long-random-string
APP_BASE_URL=http://localhost:3000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Authentication (single-user MVP) ---
AUTH_USERNAME=admin
# Generate with: python -c "from app.utils.security import hash_password; print(hash_password('yourpassword'))"
AUTH_PASSWORD_HASH=
SESSION_COOKIE_SECURE=false        # set true behind HTTPS
SESSION_TTL_MINUTES=480

# --- Database ---
DATABASE_URL=postgresql+asyncpg://aegis:aegis@localhost:5432/aegis
# For local dev without Docker you may use:
# DATABASE_URL=sqlite+aiosqlite:///./aegis.db

# --- Redis (caching + distributed locks) ---
REDIS_URL=redis://localhost:6379/0
# If Redis is unavailable in dev, the app falls back to a process-local lock
ALLOW_LOCAL_LOCK_FALLBACK=true

# --- Broker: Alpaca PAPER trading only ---
# Get paper keys at https://app.alpaca.markets (Paper Trading section)
BROKER_PROVIDER=mock               # mock | alpaca_paper
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_API_SECRET=
# The paper endpoint is hard-coded in the adapter; there is no live endpoint setting.

# --- Market data ---
MARKET_DATA_PROVIDER=mock          # mock | alpaca
STALE_PRICE_MAX_AGE_MINUTES=30

# --- AI news analysis (optional; app works fully without it) ---
AI_PROVIDER=mock                   # mock | anthropic
AI_API_KEY=
AI_MODEL_NAME=claude-sonnet-5
AI_MIN_CONFIDENCE=0.6
AI_MAX_ARTICLE_CHARS=6000

# --- Safety: live trading is DISABLED and must remain so ---
# The application refuses to start a live broker client regardless of this value.
LIVE_TRADING_ENABLED=false

# --- Scheduler ---
SCHEDULER_ENABLED=false
REBALANCE_CRON=0 15 * * MON        # UTC, weekly

# --- Notifications ---
NOTIFY_CONSOLE=true
NOTIFY_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFY_EMAIL_TO=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=10
